const firstSentence = (value?: string) => {
  if (!value) return "";
  const normalized = value.replace(/\s+/g, " ").trim();
  if (!normalized) return "";
  const match = normalized.match(/^[^.!?]+[.!?]/);
  return (match ? match[0] : normalized).trim();
};

const node: TreeNode = {
  ...siteTree,
  title: ES_HOME_ROOT_TITLE,
  updatedIso: ES_HOME_UPDATED_ISO,
  children: (siteTree.children ?? []).map((child) => {
    const localized = ES_HOME_CHILD_COPY[child.slug];
    if (!localized) return child;
    return {
      ...child,
      title: localized.title,
      description: localized.description,
    };
  }),
};
const segments: string[] = [];
const lang = "es";
const pageTitle = ES_HOME_TITLE;
const pageDescription = ES_HOME_DESCRIPTION;
const canonicalUrl = absoluteUrl("/es/");
const alternateEnUrl = absoluteUrl("/");
const alternateEsUrl = canonicalUrl;
const schemaNodes = buildCollectionSchemaNodes({
  canonicalUrl,
  routePath: "/",
  node,
  lang,
  description: pageDescription,
});
const homeUpdateTickerItems = (await getHomeLeafTickerItems(siteTree)).map((item) => {
  const localized = localizedContentByPath[item.path]?.es;
  const manual = ES_HOME_TICKER_COPY[item.path];
  const title = localized?.title ?? manual?.title ?? item.leafTitle;
  const detail =
    firstSentence(localized?.quickAnswer) ||
    firstSentence(localized?.description) ||
    manual?.detail ||
    item.detail;
  return {
    ...item,
    leafTitle: title,
    detail,
  };
});
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  bodyClass="home-bg"
  lang={lang}
  canonicalUrl={canonicalUrl}
  alternateEnUrl={alternateEnUrl}
  alternateEsUrl={alternateEsUrl}
  schemaNodes={schemaNodes}
  updatedIso={ES_HOME_UPDATED_ISO}
>
  <TreePage
    node={node}
    segments={segments}
    parentPath="/"
    isHome
    lang={lang}
    homeUpdateTickerItems={homeUpdateTickerItems}
  />
</BaseLayout>
