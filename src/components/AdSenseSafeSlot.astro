---
import { ADSENSE_CLIENT_ID, getAdSlotByZone, type AdZone } from "../lib/ads";

type Props = {
  zone: AdZone;
  className?: string;
};

const { zone, className = "" } = Astro.props as Props;
const slotId = getAdSlotByZone(zone);
const rawApprovalMode = String(
  import.meta.env.PUBLIC_ADSENSE_APPROVAL_MODE ?? import.meta.env.PUBLIC_AD_APPROVAL_MODE ?? "locked"
)
  .trim()
  .toLowerCase();
const adsApprovalMode: "locked" | "flex" = rawApprovalMode === "flex" ? "flex" : "locked";
const lockedZoneAllowlist: readonly AdZone[] = [
  "home_after_update_bar",
  "hub_after_grid",
  "leaf_end_content",
];
const isZoneAllowed = adsApprovalMode === "locked" ? lockedZoneAllowlist.includes(zone) : true;
const isConfigured = Boolean(ADSENSE_CLIENT_ID && slotId);
const isEnabled = isConfigured && isZoneAllowed;
const showPlaceholder = import.meta.env.DEV && !isEnabled;
---

{isEnabled ? (
  <div
    class={`ad-safe-slot ${className}`}
    data-ad-zone={zone}
    data-ad-approval-mode={adsApprovalMode}
    data-kpi-section="adsense_slot"
  >
    <p class="ad-safe-label">Advertisement</p>
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={ADSENSE_CLIENT_ID}
      data-ad-slot={slotId}
      data-ad-format="auto"
      data-full-width-responsive="true"
    />
    <script is:inline define:vars={{ ADSENSE_CLIENT_ID }}>
      (() => {
        const clientId = ADSENSE_CLIENT_ID;
        if (!clientId) return;
        const currentScript = document.currentScript;
        const slotEl =
          currentScript && currentScript.previousElementSibling instanceof HTMLElement
            ? currentScript.previousElementSibling
            : null;
        const slotContainer =
          currentScript && currentScript.parentElement instanceof HTMLElement
            ? currentScript.parentElement
            : null;
        const collapsedClassName = "ad-safe-slot--collapsed";

        const setCollapsed = (collapsed) => {
          if (!slotContainer) return;
          slotContainer.classList.toggle(collapsedClassName, collapsed);
          if (collapsed) {
            slotContainer.setAttribute("data-ad-collapsed", "1");
            return;
          }
          slotContainer.removeAttribute("data-ad-collapsed");
        };

        const isLikelyFilled = () => {
          if (!slotEl) return false;
          const status = slotEl.getAttribute("data-ad-status");
          if (status === "filled") return true;
          if (slotEl.querySelector("iframe")) return true;
          if (slotEl.querySelector("[data-google-query-id]")) return true;
          return false;
        };

        const refreshCollapseState = () => {
          if (!slotEl) return;
          if (isLikelyFilled()) {
            setCollapsed(false);
            return;
          }
          if (slotEl.getAttribute("data-ad-status") === "unfilled") {
            setCollapsed(true);
          }
        };

        let collapseRefreshRafId = 0;
        const scheduleCollapseRefresh = () => {
          if (collapseRefreshRafId) return;
          collapseRefreshRafId = window.requestAnimationFrame(() => {
            collapseRefreshRafId = 0;
            refreshCollapseState();
          });
        };

        const watchFillState = () => {
          if (!slotEl) return;
          const observer = new MutationObserver(scheduleCollapseRefresh);
          observer.observe(slotEl, {
            attributes: true,
            attributeFilter: ["data-ad-status"],
            childList: true,
            subtree: true,
          });

          window.setTimeout(() => {
            scheduleCollapseRefresh();
            if (!isLikelyFilled()) {
              setCollapsed(true);
            }
          }, 8000);
        };

        const enqueue = () => {
          if (!slotEl || slotEl.dataset.adsInit === "1") return;
          slotEl.dataset.adsInit = "1";
          const queue = (window.adsbygoogle = window.adsbygoogle || []);
          queue.push({});
        };

        const loadScript = () => {
          if (window.__adsenseLoaderPromise) {
            return window.__adsenseLoaderPromise;
          }

          const existing = document.querySelector("script[data-adsense-loader]");
          if (existing) {
            window.__adsenseLoaderPromise = Promise.resolve();
            return window.__adsenseLoaderPromise;
          }

          window.__adsenseLoaderPromise = new Promise((resolve, reject) => {
            const script = document.createElement("script");
            script.async = true;
            script.crossOrigin = "anonymous";
            script.src = `https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${clientId}`;
            script.setAttribute("data-adsense-loader", "true");
            script.addEventListener("load", () => resolve(), { once: true });
            script.addEventListener("error", () => reject(new Error("adsense_load_failed")), { once: true });
            document.head.appendChild(script);
          });

          return window.__adsenseLoaderPromise;
        };

        const schedule = () => {
          loadScript()
            .catch(() => null)
            .finally(enqueue);
        };

        const waitForStartSignal = () => {
          if (window.__visitkoreaAdStartPromise) {
            return window.__visitkoreaAdStartPromise;
          }

          window.__visitkoreaAdStartPromise = new Promise((resolve) => {
            let started = false;
            const options = { passive: true };
            const startNow = () => {
              if (started) return;
              started = true;
              cleanup();
              resolve();
            };
            const cleanup = () => {
              window.removeEventListener("pointerdown", startNow, options);
              window.removeEventListener("keydown", startNow, options);
              window.removeEventListener("touchstart", startNow, options);
              window.removeEventListener("scroll", startNow, options);
            };
            const startSoft = () => {
              if (started) return;
              if ("requestIdleCallback" in window) {
                window.requestIdleCallback(startNow, { timeout: 3000 });
                return;
              }
              window.setTimeout(startNow, 1800);
            };

            window.addEventListener("pointerdown", startNow, options);
            window.addEventListener("keydown", startNow, options);
            window.addEventListener("touchstart", startNow, options);
            window.addEventListener("scroll", startNow, options);

            if (document.readyState === "complete") {
              startSoft();
            } else {
              window.addEventListener("load", startSoft, { once: true });
            }
            window.setTimeout(startNow, 12000);
          });

          return window.__visitkoreaAdStartPromise;
        };

        const scheduleWhenIdle = () => {
          if ("requestIdleCallback" in window) {
            window.requestIdleCallback(schedule, { timeout: 3000 });
            return;
          }
          window.setTimeout(schedule, 900);
        };

        const waitForSlotSignal = () => {
          if (!("IntersectionObserver" in window) || !slotEl) {
            return Promise.resolve();
          }

          return new Promise((resolve) => {
            let done = false;
            const finish = () => {
              if (done) return;
              done = true;
              observer.disconnect();
              resolve();
            };
            const observer = new IntersectionObserver(
              (entries) => {
                if (!entries.some((entry) => entry.isIntersecting)) return;
                finish();
              },
              { rootMargin: "300px 0px" }
            );
            observer.observe(slotEl);
            window.setTimeout(finish, 12000);
          });
        };

        watchFillState();
        Promise.all([waitForStartSignal(), waitForSlotSignal()]).then(scheduleWhenIdle);
      })();
    </script>
  </div>
) : showPlaceholder ? (
  <div
    class={`ad-safe-slot ad-safe-slot--placeholder ${className}`}
    data-ad-zone={zone}
    data-ad-approval-mode={adsApprovalMode}
    aria-hidden="true"
  >
    <p class="ad-safe-label">Ad template: {zone}{isZoneAllowed ? "" : " (blocked in locked mode)"}</p>
  </div>
) : null}

<style>
  .ad-safe-slot {
    margin: 18px 0;
    padding: 14px 12px;
    min-height: 156px;
    border-radius: 14px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: rgba(255, 255, 255, 0.72);
  }

  .adsbygoogle {
    min-height: 108px;
  }

  .ad-safe-slot--placeholder {
    border-style: dashed;
    background: rgba(255, 255, 255, 0.46);
  }

  .ad-safe-slot--collapsed {
    margin: 0 !important;
    padding: 0 !important;
    min-height: 0 !important;
    max-height: 0 !important;
    border: 0 !important;
    background: transparent !important;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }

  .ad-safe-slot--collapsed .ad-safe-label {
    display: none;
  }

  .ad-safe-slot--collapsed .adsbygoogle {
    min-height: 0 !important;
    height: 0 !important;
  }

  .ad-safe-label {
    margin: 0 0 10px;
    font-size: 0.76rem;
    line-height: 1;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(46, 42, 38, 0.68);
  }

  @media (max-width: 720px) {
    .ad-safe-slot {
      margin: 14px 0;
      padding: 12px 10px;
      min-height: 142px;
    }

    .adsbygoogle {
      min-height: 96px;
    }
  }
</style>
