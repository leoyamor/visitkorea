  if (!localizedCopy) return undefined;
  const hasContent =
    typeof localizedCopy.title === "string" ||
    typeof localizedCopy.description === "string" ||
    typeof localizedCopy.quickAnswer === "string" ||
    (Array.isArray(localizedCopy.content) && localizedCopy.content.length > 0) ||
    (localizedCopy.children && Object.keys(localizedCopy.children).length > 0);

  if (!hasContent) return undefined;

  return {
    title: localizedCopy.title ?? currentNode.title,
    description: localizedCopy.description ?? currentNode.description,
    quickAnswer: localizedCopy.quickAnswer ?? currentNode.quickAnswer,
    content: localizedCopy.content ?? currentNode.content,
    children: localizedCopy.children,
  };
};

