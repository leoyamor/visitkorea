  /^((?:\p{Extended_Pictographic}(?:\uFE0F|\uFE0E)?(?:\u200D\p{Extended_Pictographic}(?:\uFE0F|\uFE0E)?)*)|(?:[0-9#*]\uFE0F?\u20E3))\s*/u;

const getHeadingDisplay = (title: string, iconKey?: string) => {
  const mappedIcon = renderIcon(iconKey);
  if (mappedIcon) {
    return { icon: mappedIcon, title };
  }
  const match = title.match(headingEmojiPattern);
  if (!match) {
    return { icon: null, title };
  }
  const cleanTitle = title.slice(match[0].length).trimStart();
  return {
    icon: match[1],
    title: cleanTitle.length > 0 ? cleanTitle : title,
  };
};

