};

const isAbsoluteHttpUrl = (url: string) => /^https?:\/\//i.test(url);
const EMPTY_EXCLUDED_KEYWORDS = new Set<string>();
const KEYWORD_LINK_EXCLUSIONS_BY_PATH: Record<string, Set<string>> = {
